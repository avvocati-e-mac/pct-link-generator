{
  "name": "pct-link-generator",
  "version": "0.6.1",
  "description": "App desktop per aggiungere annotazioni link ai PDF degli atti PCT",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "build": "electron-builder --publish never --config electron-builder.config.cjs",
    "dist:mac": "electron-builder --mac --publish never --config electron-builder.config.cjs",
    "dist:win": "electron-builder --win --publish never --config electron-builder.config.cjs",
    "dist:linux": "electron-builder --linux --publish never --config electron-builder.config.cjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "vitest": "^2.1.8"
  }
}
