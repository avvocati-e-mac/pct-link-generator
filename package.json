{
  "name": "pct-link-generator",
  "version": "0.3.0",
  "description": "App desktop per aggiungere annotazioni link ai PDF degli atti PCT",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "build": "electron-builder --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never"
  },
  "dependencies": {
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "vitest": "^2.1.8"
  }
}
